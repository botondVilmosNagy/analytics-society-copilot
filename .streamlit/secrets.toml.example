CHUNK_SIZE = "1200"
CHUNK_OVERLAP = "180"
INGEST_BATCH_SIZE = "64"

CHAT_MODEL = "gpt-4o-mini"
WHISPER_MODEL = "whisper-1"
TTS_MODEL = "gpt-4o-mini-tts"
