OPENAI_API_KEY=your_openai_api_key_here

# Existing Chroma settings from your setup
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=context_db
EMBEDDING_MODEL=text-embedding-3-large

# Ingestion settings
SLIDES_PDF_PATH=data/slides/context.pdf
COURSE_NAME=Analytics and Society
CHUNK_SIZE=1200
CHUNK_OVERLAP=180
INGEST_BATCH_SIZE=64

# LLM + audio model choices
CHAT_MODEL=gpt-4o-mini
WHISPER_MODEL=whisper-1
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy

# Retrieval tuning
TOP_K=6
MIN_RELEVANCE_SCORE=0.0

# Optional exact metadata filter (empty by default)
COURSE_WEEK_FILTER=
