# Non-secret runtime configuration committed to git.
# OPENAI_API_KEY is intentionally excluded and must be provided via .env (local)
# or Streamlit Community Cloud Secrets (production).

CHROMA_PERSIST_DIRECTORY=./context_db
CHROMA_COLLECTION_NAME=context_db
EMBEDDING_MODEL=text-embedding-3-large

SLIDES_PDF_PATH=data/slides/context.pdf
COURSE_NAME=Analytics and Society
CHUNK_SIZE=1200
CHUNK_OVERLAP=180
INGEST_BATCH_SIZE=64

CHAT_MODEL=gpt-4o-mini
WHISPER_MODEL=whisper-1
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy

TOP_K=6
MIN_RELEVANCE_SCORE=0.0
COURSE_WEEK_FILTER=
